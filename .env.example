# ─── Supabase (Canada region) ────────────────────────────────────────────────
# URL du projet Supabase (ex: https://xxxx.supabase.co)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé service-role — accès total, côté serveur uniquement, jamais exposée au client
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clé anon/public — utilisée par le dashboard pour l'auth (middleware + SSR)
SUPABASE_ANON_KEY=eyJhbGci...

# ─── Twilio — call tracking & SMS automation ─────────────────────────────────
# SID de compte Twilio (commence par AC)
TWILIO_ACCOUNT_SID=

# Token d'authentification Twilio
TWILIO_AUTH_TOKEN=

# ─── DataForSEO — ranking checks & keyword research ──────────────────────────
# Login DataForSEO (adresse e-mail)
DATAFORSEO_LOGIN=

# Mot de passe DataForSEO
DATAFORSEO_PASSWORD=

# ─── Google Places API — prospection de business locaux ──────────────────────
# Clé API Google Places (activer "Places API" dans Google Cloud Console)
GOOGLE_PLACES_API_KEY=

# ─── Google Search Console — suivi d'indexation & impressions ────────────────
# E-mail du service account Google (format: nom@projet.iam.gserviceaccount.com)
GSC_CLIENT_EMAIL=

# Clé privée du service account (copier le bloc -----BEGIN PRIVATE KEY----- complet)
GSC_PRIVATE_KEY=

# ─── Stripe — facturation clients & abonnements upsells ──────────────────────
# Clé secrète Stripe (sk_live_... en prod, sk_test_... en dev)
STRIPE_SECRET_KEY=

# ─── Vercel — déploiement automatique des sites locaux ───────────────────────
# Token Vercel (créer dans Account Settings > Tokens)
VERCEL_TOKEN=

# ─── Anthropic — génération de contenu pour les sites ────────────────────────
# Clé API Anthropic (générer sur console.anthropic.com)
ANTHROPIC_API_KEY=

# ─── Namecheap — achat de domaines ──────────────────────────────────────────
# Créer un compte revendeur sur namecheap.com et activer l'API
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=   # IP publique de la machine qui appelle l'API
