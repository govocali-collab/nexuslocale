{
  "name": "@nexuslocale/images",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Génère des visuels de marque (hero, OG) avec Satori",
  "main": "./dist/generate.js",
  "bin": {
    "generate-images": "./dist/generate.js"
  },
  "scripts": {
    "build":     "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "generate":  "node dist/generate.js"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "satori":          "^0.10.13"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript":  "^5.4.5"
  }
}
